# PostgreSQL local via Homebrew (postgresql@16) — ajuste usuário/porta conforme sua config local
DATABASE_URL="postgresql://seu_usuario@localhost:5432/conciliai?schema=public"

# Chave da API Anthropic (usada pelos agentes de IA)
ANTHROPIC_API_KEY="sk-ant-..."

# Redis (fila de processamento assincrono via BullMQ)
REDIS_HOST="127.0.0.1"
REDIS_PORT="6379"

PORT=3001
